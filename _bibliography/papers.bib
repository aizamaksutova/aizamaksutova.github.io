@article{maksutova2026affordtissue,
  title        = {AffordTissue: Dense Affordance Prediction for Tool-Action Specific Tissue Interaction},
  author       = {Maksutova, Aiza and Seenivasan, Lalithkumar and Ding, Hao and Xu, Jiru and Yu, Chenhao and Jing, Chenyan and Shen, Yiqing and Unberath, Mathias},
  journal      = {arXiv preprint arXiv:2604.01371},
  year         = {2026},
  arxiv        = {2604.01371},
  html         = {https://arxiv.org/abs/2604.01371},
  preview      = {affordtissue_preview.svg},
  selected     = {true},
  abstract     = {Surgical robotic systems and AI-assisted interventions require precise understanding of how tools should
                  interact with tissue. We introduce AffordTissue, a framework for dense affordance prediction that maps
                  every pixel of an endoscopic scene to an action-specific interaction probability, conditioned on the
                  type of surgical tool and action. Our approach leverages geometric priors and texture cues from
                  endoscopic imagery to produce spatially dense affordance maps that guide downstream motion planning
                  and intraoperative decision support.},
  bibtex_show  = {true}
}

@article{schneider2026towards,
  title        = {Towards Controllable Video Synthesis of Routine and Rare OR Events},
  author       = {Schneider, Dominik and Seenivasan, Lalithkumar and Rapuri, Sampath and Anil, Vishalroshan and Maksutova, Aiza and Shen, Yiqing and Mangulabnan, Jan Emily and Ding, Hao and Porras, Jose L. and Ishii, Masaru and others},
  journal      = {arXiv preprint arXiv:2602.21365},
  year         = {2026},
  arxiv        = {2602.21365},
  html         = {https://arxiv.org/abs/2602.21365},
  preview      = {endosynth_preview.svg},
  selected     = {true},
  abstract     = {Collecting and annotating real surgical video at scale is prohibitively expensive and raises patient
                  privacy concerns. We present a controllable video diffusion framework capable of synthesizing
                  photorealistic operating room scenes — including both routine and rare surgical events — conditioned
                  on structured scene descriptions. Our approach enables fine-grained control over instrument type,
                  tissue state, and procedural phase, producing diverse training data that improves downstream
                  perception models.},
  bibtex_show  = {true}
}

@article{shen2025counterfactual,
  title        = {Counterfactual World Models via Digital Twin-conditioned Video Diffusion},
  author       = {Shen, Yiqing and Maksutova, Aiza and Li, Chenjia and Unberath, Mathias},
  journal      = {arXiv preprint arXiv:2511.17481},
  year         = {2025},
  arxiv        = {2511.17481},
  html         = {https://arxiv.org/abs/2511.17481},
  preview      = {counterfactual_preview.svg},
  selected     = {true},
  abstract     = {We propose a framework for learning counterfactual world models in surgical settings by conditioning
                  video diffusion on a paired digital twin representation. Given a reference video and a modified
                  scene configuration expressed via the digital twin, our model synthesizes plausible counterfactual
                  outcomes — enabling surgeons and AI systems to reason about the effect of hypothetical interventions.
                  This capability is critical for simulation, surgical training, and safe planning in complex procedures.},
  bibtex_show  = {true}
}
